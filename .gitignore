# =============================================================================
# DerasaX monorepo root .gitignore
#
# Tracks the full DerasaX monorepo: the three active applications
# (backend/, frontend/, ai/) plus workspace-owned orchestration and docs
# (docker-compose.yml, .env.example, scripts/, infra/, docs/). Each app also
# carries its own nested .gitignore, honored by Git in addition to the rules
# below. Remote: github.com/mustafa-elshahhat/drasa-x
# =============================================================================

# --- Local environment / secrets (never tracked) ----------------------------
.env
*.env
!*.env.example

# --- Runtime process metadata + per-service logs ----------------------------
/.runtime/

# --- Local database cluster (native PostgreSQL data dir) --------------------
/.localdb/
pgdata/
*.sqlite3
*.db

# --- AI indexes / model binaries --------------------------------------------
vectorstore/
*.pkl

# --- Build output -----------------------------------------------------------
dist/
bin/
obj/

# --- Node / Python ----------------------------------------------------------
node_modules/
.venv/
venv/
__pycache__/
*.pyc

# --- Editor / OS / temp -----------------------------------------------------
*.tmp
Thumbs.db
.DS_Store
