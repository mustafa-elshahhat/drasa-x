# =============================================================================
# school-ai-frontend (authenticated app) — environment template
# Copy to ".env" (or ".env.local", both gitignored):  cp .env.example .env
# Vite exposes ONLY variables prefixed with VITE_ to the browser. Never place a
# secret in a VITE_ variable — anything here ships to the client.
#
# All variables are read and validated in ONE place: src/config/env.js. No
# component reads import.meta.env directly. Missing/invalid required config fails
# the production build loudly (Phase 7 §2).
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED. DerasaX-backend (the .NET system of record) base URL.
# The SPA's ONLY backend origin. MUST point at DerasaX-backend, NEVER the
# archived backend. Use the environment-appropriate value:
#   local:      http://localhost:5155
#   test:       http://localhost:5155
#   staging:    https://<staging-backend-host>
#   production: https://<production-backend-host>
# ---------------------------------------------------------------------------
VITE_DOTNET_URL=http://localhost:5155

# ---------------------------------------------------------------------------
# OPTIONAL. Explicit environment name: local | test | staging | production.
# Falls back to Vite's MODE when unset. Drives telemetry/diagnostics behavior.
# ---------------------------------------------------------------------------
# VITE_APP_ENV=local

# ---------------------------------------------------------------------------
# OPTIONAL. Frontend telemetry sink (endpoint/DSN) for Phase 19 integration.
# When empty, telemetry stays in a safe dev-console / no-op mode and there is NO
# mandatory third-party production dependency. NOT a secret-bearing value.
# ---------------------------------------------------------------------------
# VITE_TELEMETRY_DSN=

# ---------------------------------------------------------------------------
# school-ai-rag (AI service) — INTENTIONALLY ABSENT.
# The browser MUST NOT call the AI service directly. All AI calls are proxied
# through DerasaX-backend (the API client is backend-only and rejects absolute
# URLs). Do NOT add a VITE_API_URL pointing at the AI service — the backend
# issues the signed service token and talks to school-ai-rag (Phase 3/6 §18).
# ---------------------------------------------------------------------------
# VITE_API_URL=  (intentionally removed)
