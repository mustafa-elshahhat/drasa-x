# =============================================================================
# school-ai-rag — LOCAL environment template (placeholders only)
# Copy to ".env" (gitignored) and fill in real local values:  cp .env.example .env
# Never commit a real GROQ_API_KEY.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED for any LLM-backed endpoint (chat, quiz generation, analyze).
# Get a key from https://console.groq.com/ and paste it here. Leave BLANK to
# run without AI: the service still starts and /health/* work; /health/ready
# then reports groq_api_key="missing".
# ---------------------------------------------------------------------------
GROQ_API_KEY=

# ---------------------------------------------------------------------------
# Service port (used by uvicorn). Default 8000.
# ---------------------------------------------------------------------------
PORT=8000

# ---------------------------------------------------------------------------
# Persistent local data locations. Defaults are inside the repo.
# ---------------------------------------------------------------------------
VECTORSTORE_DIR=./vectorstore
MODEL_DIR=./app/models

# ---------------------------------------------------------------------------
# CORS allow-list (comma-separated). The browser NEVER calls this internal
# service (the backend mediates all AI traffic server-to-server), so this is
# EMPTY by default — no browser/SPA origin is advertised. Set it only if a
# same-origin internal docs/UI genuinely needs CORS. (Phase 22 / AI-01.)
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# RAG embeddings (§14). The embedding model id IS the embedding-model version
# recorded with indexed documents and reported by /health/ready.
# (Defaults to sentence-transformers/all-MiniLM-L6-v2 in app/rag/indexer.py.)
# ---------------------------------------------------------------------------
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---------------------------------------------------------------------------
# Provider / model selection (§14) — config-only; never hardcoded in code.
# ---------------------------------------------------------------------------
# AI_PROVIDER=groq
# AI_TUTOR_MODEL=llama-3.1-8b-instant
# AI_QUIZ_MODEL=llama-3.1-8b-instant
# AI_ANALYSIS_MODEL=llama-3.1-8b-instant
# AI_TUTOR_MODEL_VERSION / AI_QUIZ_MODEL_VERSION / AI_ANALYSIS_MODEL_VERSION (default = model id)
# AI_PROVIDER_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Retrieval tuning (§8). No-answer threshold + bounded context/snippet sizes.
# ---------------------------------------------------------------------------
# RAG_MIN_SCORE=0.2
# RAG_SNIPPET_MAX_CHARS=320
# RAG_MAX_CONTEXT_CHARS=6000

# ---------------------------------------------------------------------------
# Prediction model (§12) — config-only; the service NEVER downloads a model.
# ---------------------------------------------------------------------------
# MODEL_REGRESSOR_FILENAME=rf_regressor.pkl
# MODEL_CLASSIFIER_FILENAME=rf_classifier.pkl
# AI_PREDICTION_MODEL_NAME=rf-performance
# AI_PREDICTION_MODEL_VERSION=rf-2026.06
# FEATURE_SCHEMA_VERSION=perf-v1
# Optional integrity check (sha256 of each .pkl); unset = skip:
# MODEL_REGRESSOR_SHA256=
# MODEL_CLASSIFIER_SHA256=

# ---------------------------------------------------------------------------
# Phase 15 — Computer-vision (classroom attendance + engagement).
# CV_ENGINE selects the inference backend:
#   auto  (default) = use the real torch engine IF its deps + model files are
#                     present in CV_MODEL_DIR, otherwise the deterministic STUB.
#   stub            = always use the deterministic stub (local/dev/CI; degraded).
#   torch           = force the real engine; 503 if deps/model files are missing.
# The service NEVER downloads CV weights. Real models must be placed in
# CV_MODEL_DIR (emotion.pth, engagement.pth; optional svm_face.pkl + normalizer.pkl
# + centroids.pkl for recognition). Install heavy deps from requirements-vision.txt.
# /health/ready reports CV readiness SEPARATELY (vision_engine_active / vision_models).
# ---------------------------------------------------------------------------
# CV_ENGINE=auto
# CV_MODEL_DIR=./app/models/vision
# CV_MODEL_VERSION=cv-2026.06
# CV_RECOGNITION_THRESHOLD=0.5

# ---------------------------------------------------------------------------
# Logging (§17). Telemetry is structured + secret-masked; payloads never logged.
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Phase 3 — Internal service-token validation (from DerasaX-backend).
# MUST match the backend's ServiceAuth__SigningKey. The AI service rejects all
# application routes without a valid signed service token. LOCAL ONLY.
# ---------------------------------------------------------------------------
SERVICE_AUTH_SIGNING_KEY=CHANGE_ME_LOCAL_SERVICE_SIGNING_KEY_AT_LEAST_32_CHARS
SERVICE_AUTH_ISSUER=derasax-backend
SERVICE_AUTH_AUDIENCE=school-ai-rag
SERVICE_AUTH_CLOCK_SKEW_SECONDS=60
SERVICE_AUTH_MAX_TTL_SECONDS=300
