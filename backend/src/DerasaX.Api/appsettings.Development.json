{
  // ---------------------------------------------------------------------------
  // LOCAL DEVELOPMENT DEFAULTS ONLY.
  //
  // These values target a LOCAL PostgreSQL database (derasax_local) and use a
  // LOCAL-ONLY JWT signing key. They are NOT production secrets and must never
  // be used in any deployed environment.
  //
  // Any value here can be overridden by environment variables (which take
  // precedence), e.g. ConnectionStrings__cs, SecretKey, Cors__AllowedOrigins__0.
  // The start-local script and docker-compose set these from a local .env file.
  // ---------------------------------------------------------------------------
  "ConnectionStrings": {
    "cs": "Host=localhost;Port=5432;Database=derasax_local;Username=derasax;Password=derasax_local_dev;SSL Mode=Disable;Trust Server Certificate=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "SecretKey": "local-dev-only-signing-key-not-for-production-0123456789abcdef",
  // LOCAL-ONLY service signing key for backend → school-ai-rag tokens. The same
  // value must be configured on school-ai-rag (SERVICE_AUTH_SIGNING_KEY).
  "ServiceAuth": {
    "SigningKey": "local-dev-only-service-signing-key-not-for-production-abcdef0123456789"
  },
  // Internal AI service (school-ai-rag) base URL + per-request timeout. Local default.
  "AiService": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "http://localhost:4173",
      "http://127.0.0.1:4173"
    ]
  },
  "Seed": {
    "Enabled": true
  },
  // LOCAL DEVELOPMENT ONLY. The rate limiter stays ENABLED so every policy is
  // still exercised locally, but the anonymous "auth" surface (login/refresh/
  // password) is given generous headroom. A local E2E/QA pass logs in many
  // times in one minute (login + token refresh + /me per scenario across
  // Playwright workers) and the production default of 10/60 would (correctly)
  // throttle that. Production appsettings.json is unchanged and keeps the strict
  // 10/60 brute-force limit. The integration test host disables the limiter
  // entirely (RateLimiting:Enabled=false); this is the same sanctioned pattern
  // of relaxing abuse limits for test contexts without touching production.
  "RateLimiting": {
    "Enabled": true,
    "Policies": {
      "auth": { "PermitLimit": 200, "WindowSeconds": 60, "QueueLimit": 0 }
    }
  },
  // Phase 16 — LOCAL durable file storage. Local provider writes under App_Data/FileStorage
  // beside the running app. The signing key is LOCAL-ONLY (HMAC for signed-download tokens);
  // production supplies FileStorage:SigningKey + S3 credentials via environment/secret store.
  "FileStorage": {
    "Provider": "Local",
    "SignedUrlTtlSeconds": 300,
    "SigningKey": "local-dev-only-file-download-signing-key-not-for-production-0123456789abcdef"
  }
}
