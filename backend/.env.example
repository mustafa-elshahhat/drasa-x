# =============================================================================
# backend — LOCAL environment template (placeholders only)
# =============================================================================
# Copy to ".env" and adjust if needed:   cp .env.example .env
# The real ".env" file is gitignored and must never contain a production secret.
#
# Configuration precedence (highest wins):
#   environment variables  >  appsettings.Development.json  >  appsettings.json
# ASP.NET maps the "__" (double underscore) in env var names to ":" config keys.
# =============================================================================

# Which environment to run as. Use "Development" locally. NEVER "Production" here.
ASPNETCORE_ENVIRONMENT=Development

# HTTP/HTTPS endpoints the Kestrel server binds to.
ASPNETCORE_URLS=http://localhost:5155

# ---------------------------------------------------------------------------
# PostgreSQL connection (LOCAL ONLY).
# Must point at the local database (derasax_local). Never the committed Neon DB.
# ---------------------------------------------------------------------------
ConnectionStrings__cs=Host=localhost;Port=5432;Database=derasax_local;Username=derasax;Password=CHANGE_ME_LOCAL_DB_PASSWORD;SSL Mode=Disable;Trust Server Certificate=true

# ---------------------------------------------------------------------------
# JWT signing key (LOCAL ONLY, >= 32 bytes). Generate a fresh random value.
# Do NOT reuse any key committed in source control.
# ---------------------------------------------------------------------------
SecretKey=CHANGE_ME_LOCAL_DEV_JWT_KEY_AT_LEAST_32_CHARS

# ---------------------------------------------------------------------------
# CORS allowed origins for the unified local frontend (indexed array binding):
# dev server :5173 and preview server :4173.
# ---------------------------------------------------------------------------
Cors__AllowedOrigins__0=http://localhost:5173
Cors__AllowedOrigins__1=http://localhost:4173

# ---------------------------------------------------------------------------
# Development seed data. Only honoured in Development/Test; never in Production.
# ---------------------------------------------------------------------------
Seed__Enabled=true

# ---------------------------------------------------------------------------
# Phase 3 — security configuration (names only; LOCAL values go in .env).
# ---------------------------------------------------------------------------
Seed__DefaultPassword=CHANGE_ME_LOCAL_SEED_PASSWORD
Jwt__Issuer=derasax-backend
Jwt__Audience=derasax-frontend
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=10
Jwt__ClockSkewSeconds=30
# ServiceAuth__SigningKey MUST match the AI service SERVICE_AUTH_SIGNING_KEY (>=32 chars).
ServiceAuth__SigningKey=CHANGE_ME_LOCAL_SERVICE_SIGNING_KEY_AT_LEAST_32_CHARS
ServiceAuth__Issuer=derasax-backend
ServiceAuth__Audience=school-ai-rag
ServiceAuth__TtlSeconds=120
Auth__Lockout__MaxFailedAttempts=5
Auth__Lockout__LockoutMinutes=15
Auth__Password__RequiredLength=8
Cookie__SameSite=Lax
