# =============================================================================
# DerasaX — WORKSPACE local environment template (placeholders only)
#
# Used by docker-compose.yml and the scripts/*.ps1 helpers.
# Copy to ".env" (gitignored) and adjust:   cp .env.example .env
#
# NEVER put a production secret here. These are LOCAL-ONLY values.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (local)
# ---------------------------------------------------------------------------
POSTGRES_USER=derasax
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DB_PASSWORD
POSTGRES_DB=derasax_local
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# backend (.NET)
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
BACKEND_PORT=5155
# Local-only JWT signing key (>= 32 chars). Generate a fresh random value.
BACKEND_JWT_KEY=CHANGE_ME_LOCAL_DEV_JWT_KEY_AT_LEAST_32_CHARS
# Run development seed data (Development/Test only; never honoured in Production).
SEED_ENABLED=true

# ---------------------------------------------------------------------------
# ai (FastAPI)
# ---------------------------------------------------------------------------
AIRAG_PORT=8000
# Optional locally: without it the AI service still starts and health checks work,
# but LLM-backed endpoints (chat/quiz/analyze) are unavailable and readiness
# reports groq_api_key="missing".
GROQ_API_KEY=
AIRAG_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# ---------------------------------------------------------------------------
# Frontend origin (used for backend CORS). The single unified frontend
# (frontend/) runs as a local Node server: dev :5173, preview :4173.
# It serves the public marketing pages, the auth page, and the portal.
# ---------------------------------------------------------------------------
FRONTEND_AUTH_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Phase 16 — durable file storage (PLACEHOLDERS ONLY; never commit real secrets).
# Local provider needs no secrets. For production set Provider=S3 and supply the
# S3-compatible credentials below via your secret store (AWS S3 / MinIO / R2 / Spaces).
# Backend reads these as the FileStorage:* configuration section.
# ---------------------------------------------------------------------------
FileStorage__Provider=Local
FileStorage__SignedUrlTtlSeconds=300
# HMAC key for signed download tokens (production: a strong random secret; local dev
# uses the value in appsettings.Development.json).
FileStorage__SigningKey=
# Local provider root (relative paths resolve against the app base directory).
FileStorage__Local__RootPath=App_Data/FileStorage
# S3-compatible object storage (only when FileStorage__Provider=S3).
FileStorage__S3__ServiceUrl=
FileStorage__S3__Region=
FileStorage__S3__Bucket=
FileStorage__S3__AccessKeyId=
FileStorage__S3__SecretAccessKey=
FileStorage__S3__ForcePathStyle=true

# Phase 16 — optional consented CV enrollment image storage (default OFF, product-gated).
Cv__EnrollmentAssetsEnabled=false
